{
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "created_at",
    "role",
    "request",
    "scope_decision",
    "authority_used",
    "summary",
    "findings",
    "evidence",
    "unknowns",
    "recommended_next_action",
    "changed_files",
    "verification",
    "confidence"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["amadeus_worker_report_v1"] },
    "job_id": { "type": "string", "pattern": "^amadeus-job-[0-9]{8}-[0-9]{6}(-[a-z0-9-]+)?$" },
    "created_at": { "type": "string" },
    "role": {
      "type": "string",
      "enum": ["scoper", "investigator", "implementer", "verifier", "researcher", "commons-reporter"]
    },
    "request": { "type": "string" },
    "scope_decision": {
      "type": "object",
      "required": ["work_type", "needs_live_access", "needs_code_changes", "needs_followup_workers"],
      "properties": {
        "work_type": {
          "type": "string",
          "enum": ["status", "audit", "implementation", "verification", "research", "cross_suite"]
        },
        "needs_live_access": { "type": "boolean" },
        "needs_code_changes": { "type": "boolean" },
        "needs_followup_workers": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "authority_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "basis", "confidence"],
        "properties": {
          "claim": { "type": "string" },
          "basis": { "type": "string" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "unknowns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_next_action": { "type": "string" },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verification": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] }
  },
  "additionalProperties": false
}
