{
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "created_at",
    "updated_at",
    "repo_root",
    "status",
    "git_snapshot",
    "fast_brief",
    "deep_refresh",
    "live_checks",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["amadeus_session_v1"] },
    "session_id": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["fast_ready", "refresh_running", "refresh_complete", "refresh_failed"]
    },
    "git_snapshot": {
      "type": "object",
      "required": ["branch", "head", "status_lines", "recent_commits"],
      "properties": {
        "branch": { "type": ["string", "null"] },
        "head": { "type": ["string", "null"] },
        "status_lines": { "type": "array", "items": { "type": "string" } },
        "recent_commits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "fast_brief": {
      "type": "object",
      "required": ["status", "path", "generated_at"],
      "properties": {
        "status": { "type": "string", "enum": ["complete", "failed"] },
        "path": { "type": "string" },
        "generated_at": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "deep_refresh": {
      "type": "object",
      "required": [
        "status",
        "path",
        "command",
        "started_at",
        "completed_at",
        "process_id",
        "stdout_path",
        "stderr_path",
        "error"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_started", "pending", "running", "complete", "failed"]
        },
        "path": { "type": "string" },
        "command": { "type": "string" },
        "started_at": { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "process_id": { "type": ["integer", "null"] },
        "stdout_path": { "type": ["string", "null"] },
        "stderr_path": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "live_checks": {
      "type": "object",
      "required": ["network", "ssh", "browser", "api", "service_status"],
      "properties": {
        "network": { "type": "boolean" },
        "ssh": { "type": "boolean" },
        "browser": { "type": "boolean" },
        "api": { "type": "boolean" },
        "service_status": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
