{
  "type": "object",
  "required": [
    "schema_version",
    "job_id",
    "created_at",
    "updated_at",
    "repo_root",
    "session_id",
    "user_request",
    "project_hint",
    "authority",
    "requested_output",
    "status",
    "scoper",
    "worker",
    "worker_report_sha256",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["amadeus_delegation_job_v1"] },
    "job_id": { "type": "string", "pattern": "^amadeus-job-[0-9]{8}-[0-9]{6}(-[a-z0-9-]+)?$" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "session_id": { "type": ["string", "null"] },
    "user_request": { "type": "string", "minLength": 1 },
    "project_hint": { "type": "string", "minLength": 1 },
    "authority": {
      "type": "string",
      "enum": ["conversation_only", "read_only", "implementation", "live_check"]
    },
    "requested_output": {
      "type": "string",
      "enum": ["status_report", "audit_report", "implementation_report", "verification_report", "research_report", "scope_report"]
    },
    "status": {
      "type": "string",
      "enum": ["created", "running", "reported", "failed"]
    },
    "scoper": {
      "type": "object",
      "required": ["required", "prompt_path", "agent_session_dir"],
      "properties": {
        "required": { "type": "boolean" },
        "prompt_path": { "type": ["string", "null"] },
        "agent_session_dir": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "worker": {
      "type": "object",
      "required": [
        "backend",
        "profile_path",
        "prompt_path",
        "report_path",
        "agent_session_dir",
        "allowed_paths",
        "run_evidence"
      ],
      "properties": {
        "backend": { "type": ["string", "null"] },
        "profile_path": { "type": ["string", "null"] },
        "prompt_path": { "type": ["string", "null"] },
        "report_path": { "type": "string" },
        "agent_session_dir": { "type": ["string", "null"] },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "run_evidence": {
          "type": ["object", "null"],
          "required": [
            "session_id",
            "session_dir",
            "session_type",
            "contract_version",
            "backend",
            "status",
            "prompt_sha256",
            "profile_command_sha256",
            "manifest_sha256",
            "result_sha256"
          ],
          "properties": {
            "session_id": { "type": "string" },
            "session_dir": { "type": "string" },
            "session_type": { "type": "string" },
            "contract_version": { "type": "integer" },
            "backend": { "type": "string" },
            "status": { "type": "string" },
            "prompt_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "profile_command_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "result_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "worker_report_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
